{
  "name": "panjabi-colouring-book-fulfillment",
  "version": "1.0.0",
  "description": "Automated e-book and print-on-demand fulfillment for Sikh & Panjabi Cultural Colouring Books",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "bundle:widget": "tsup src/chatbot/widget.ts --format iife --out-dir public --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^4.21.0",
    "stripe": "^17.4.0",
    "resend": "^4.0.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
