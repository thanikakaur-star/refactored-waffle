# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (for selling API access)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Scraper
SCRAPE_INTERVAL_HOURS=24
PLAYWRIGHT_HEADLESS=true
# Optional: path to a pre-installed Chromium binary (e.g. on Railway)
# PLAYWRIGHT_CHROMIUM_PATH=/path/to/chromium

# Automatic scraping (in-app cron)
# Set to "true" on your deployed server (Railway) to auto-update tender data.
ENABLE_SCRAPER_CRON=false
# Cron expression: default = 03:00 every day.
# "0 3 1 * *" = monthly (1st), "0 */6 * * *" = every 6 hours.
SCRAPER_CRON=0 3 * * *
SCRAPER_TIMEZONE=Europe/London

# API Server
API_PORT=3000
API_BASE_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Currency conversion
EXCHANGE_RATE_API_KEY=your-key
BASE_CURRENCY=USD

# Logging
LOG_LEVEL=info

# Admin area (private SEO dashboard at /admin) — set a long random secret
ADMIN_TOKEN=change-me-to-a-long-random-string

# Google Search Console (powers the admin SEO dashboard)
# Create a service account in Google Cloud, enable the Search Console API,
# download its JSON key, then add the service account email as a user on your
# property in Search Console.
GSC_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL=https://healthprocureintel.com/
