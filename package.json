{
  "name": "healthprocure-intel",
  "version": "1.0.0",
  "description": "Automated healthcare procurement intelligence platform — aggregates global tenders, medical device frameworks, and supply chain benchmarks",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r public dist/public && cp -r dashboard dist/dashboard",
    "start": "node dist/server.js",
    "scrape": "tsx src/scraper/run.ts",
    "scrape:ted": "tsx src/scraper/run.ts --source=ted",
    "scrape:sam": "tsx src/scraper/run.ts --source=sam",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "stripe": "^16.12.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "playwright": "^1.61.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
